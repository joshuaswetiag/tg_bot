# Get token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Your numeric Telegram ID from @userinfobot (NOT @username)
ADMIN_IDS=123456789

# Required channel for verification (e.g. @your_channel) — leave empty to disable
REQUIRED_CHANNEL=@your_channel

# bKash payment details
BKASH_NUMBER=01845007133
BKASH_TYPE=Personal

# Nagad payment details
NAGAD_NUMBER=01845007133
NAGAD_TYPE=Personal

# Support contact shown in Help menu
SUPPORT_USERNAME=@Noyon001

# Proxy checker: max checks per user per 24 hours
CHECKER_DAILY_LIMIT=5

# Bot display name
BOT_NAME=Owl Proxy Store

# --- 24/7 cloud setup (Supabase + Railway) ---
# Supabase → Project Settings → Database → Connection string → URI
# Use "Session pooler" or "Direct connection" (port 5432)
DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres

# Local testing only (leave DATABASE_URL empty to use SQLite file)
# DB_PATH=data/bot.db
